{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://therealjameswilson.github.io/critical-minerals-records-stage-v3/schemas/observation.schema.json",
  "title": "V3 normalized statistical observation",
  "type": "object",
  "required": [
    "id", "series_id", "metric_id", "observation_kind", "reference_year",
    "reference_period_start", "reference_period_end", "frequency", "period_status",
    "focal_geography_id", "focal_role", "material_id", "material_scope",
    "measurement", "source_artifact_id", "source_locator", "review_status"
  ],
  "properties": {
    "reference_year": {"type": "integer", "minimum": 1993, "maximum": 2026},
    "observation_kind": {"enum": ["source-reported", "source-published-derived", "project-derived"]},
    "period_status": {"enum": ["final", "provisional", "year-to-date", "partial-period"]},
    "focal_role": {
      "enum": [
        "production-location", "reserve-location", "processing-location", "importer",
        "exporter", "consumer", "stockpile-holder", "owner-controller", "world"
      ]
    },
    "material_scope": {"enum": ["single-material", "material-group", "commodity-basket", "broad-resource-class"]},
    "measurement": {
      "type": "object",
      "required": ["status", "reported_value", "reported_text", "reported_unit_text"],
      "properties": {
        "status": {
          "enum": [
            "reported", "reported-zero", "less-than", "greater-than", "range",
            "suppressed", "not-available", "not-published", "not-applicable", "source-blank"
          ]
        },
        "reported_value": {"type": ["number", "null"]},
        "reported_text": {"type": ["string", "null"]},
        "reported_unit_text": {"type": ["string", "null"]}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
